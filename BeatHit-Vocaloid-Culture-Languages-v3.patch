+    "punjabi": "pa", "pa": "pa",
+    "chinese": "zh", "mandarin": "zh", "zh": "zh",
+    "cantonese": "yue", "yue": "yue",
+    "thai": "th", "th": "th",
+    "vietnamese": "vi", "vi": "vi",
+    "indonesian": "id", "id": "id",
