+        if not name:
+            continue
+        artist_type=re.sub(r"[^a-z]","",str(artist.get("artistType") or "").casefold())
+        roles=_vocadb_roles(credit.get("effectiveRoles") or credit.get("roles"))
+        is_support=bool(credit.get("isSupport"))
+        all_artists.append({
