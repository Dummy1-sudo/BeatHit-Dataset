# Optional but strongly recommended for exact VTuber YouTube view counts.
YOUTUBE_API_KEY=
# Holodex documents X-APIKEY authentication for reliable API access.
HOLODEX_API_KEY=
# Public Kaggle downloads generally work anonymously through kagglehub; credentials
# can be set if your environment/account requires them.
KAGGLE_USERNAME=
KAGGLE_KEY=
# Set to 1 to skip the 931 MB Zenodo Spotify snapshot and use smaller fallbacks.
BEATHIT_SKIP_ZENODO=0
# Without a YouTube API key, use the public Return YouTube Dislike cached viewCount fallback.
BEATHIT_RYD_FALLBACK=1
BEATHIT_RYD_WORKERS=20
BEATHIT_RYD_TIMEOUT=15
# Optional last resort for unresolved video IDs. Disabled by default because it is much slower.
BEATHIT_YTDLP_FALLBACK=0
BEATHIT_YTDLP_MAX=2000

# High-popularity VocaDB candidate scan. Default 25k respects public API usage guidance.
# Raise only when you intentionally accept a longer, heavier crawl; hard cap in builder is 250k.
BEATHIT_VOCADB_SCAN_LIMIT=25000
